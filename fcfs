#include <stdio.h>
int main() {
    int n,i,j,time=0,min,p;
    float avgTAT=0,avgWT=0;
    printf("Enter number of processes: \n");
    scanf("%d",&n);
    int at[n],bt[n],ct[n],tat[n],wt[n],done[n];
    for(i=0;i<n;i++){
        printf("Enter Arrival Time and Burst Time for P%d: \n",i+1);
        scanf("%d %d",&at[i],&bt[i]);
        done[i]=0;
    }
    for(i=0;i<n;i++){
        min=999;
        for(j=0;j<n;j++){
            if(at[j]<=time && done[j]==0 && bt[j]<min){
                min=bt[j];
                p=j;
            }
        }
        if(min==999){
            time++;
            i--;
        }else{
            time=time+bt[p];
            ct[p]=time;
            done[p]=1;
        }
    }
    for(i=0;i<n;i++){
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];
        avgTAT+=tat[i];
        avgWT+=wt[i];
    }
    printf("\nAverage Turnaround Time = %.2f\n",avgTAT/n);
    printf("Average Waiting Time = %.2f",avgWT/n);
    return 0;
}
